#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:28
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Default Tiler</"
"span>: This decides which tiler will show up when you start moving a window. "
"You can still toggle between the tilers by using the shortcut (<span "
"style=\" font-weight:700;\">Meta+Ctrl+Space</span>).</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:29
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Description</span></"
"p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:30
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">General Settings</"
"span></p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:31
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Grid Configuration</"
"span>: Change the properties of the grid, layouts and tiles.</p></body></"
"html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:32
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Input Type</span>: "
"Change the default input type (needed when you use certain Stylus or "
"Touchpad as input). You can toggle between the input types with <span "
"style=\" font-weight:700;\">Ctrl+Alt+I</span>. When using Window as input, "
"an indicator will be displayed in the top-center indicating the position "
"used by the tiler.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:33
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Layout</span>: Set "
"the layout for the Overlay mode. Valid format is either a grid [XxY] "
"(example 4x2), [X,Y,Width,Height] each value in percent (e.g. 30 or 33.33), "
"fractions (e.g. 1/3) or pixels using a px suffix (example 0,0,100,100 for a "
"full screen tile equal to 1x1), or [X,Y,Width,Height,AnchorX,AnchorY] - same "
"as previous but anchored around the anchor (example "
"100,100,50,33,RIGHT,BOTTOM for a 50% wide and 33% high tile placed in the "
"bottom right corner).</p><p>The layout can be made of multiple grids and/or "
"tiles separated by a + (example 0,0,50,100+50,0,50,100 which is equal to a "
"2x1). Please see the <span style=\" font-weight:700;\">Popup Grid Layouts</"
"span> tab for more detailed description.</p><p>WARNING - SPECIAL layouts are "
"not supported in Overlay Mode.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:34
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Meta</span> key "
"depends on your keyboard, but on most keyboards it is the Windows key. Most "
"of the shortcuts should be used while moving a window.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:35
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Mouse Position "
"Polling Rate</span>: Set the polling rate of the Overlay mode mouse "
"position. The shorter the polling rate the faster the Overlay will react to "
"mouse positions but it will introduce unnecessary calculations and might "
"introduce lag (90-200 ms is recommended for smooth experience).</p></body></"
"html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:36
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Mouse Position "
"Polling Rate</span>: Set the polling rate of the popup grid mode mouse "
"position. The shorter the polling rate the faster the Popup Grid will react "
"to mouse positions but it will introduce unnecessary calculations and might "
"introduce lag (50-150 ms is recommended for smooth experience).</p></body></"
"html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:37
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Name</span></p></"
"body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:38
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Overlay Screen Edge "
"Margin</span>: Margin around the Overlay. Increase this in case you use edge "
"snapping and want to leave a gap to allow it to work. This does not add any "
"margin around the actual window.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:39
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Popup Grid default "
"tile hint</span>: Replaces default hint with Popup Grid non-special tile "
"position and/or size (when one of the below options is enabled).</p></body></"
"html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:40
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Show Hint</span></"
"p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:41
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Virtual Desktop "
"Manager</span>: Configure if the Virtual Desktop Manager should be visible "
"and how it should behave.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:42
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Visibility</span>: "
"Determines when the default tiler is visible. Previous visibility is kept "
"when changing modes using the keyboard shortcut.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:43
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Window Margin</"
"span>: Set the margin around windows. Set the additional screen edge margin "
"to -1 px if you use screen scaling and experience gaps around screen edges.</"
"p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:44
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Window Suggestions</"
"span>: Configure if suggestions should be automatically shown for other "
"tiles, and which windows should be suggested. Suggestions are only available "
"for regular tiles.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:45
msgid ""
"<html><head/><body><p>Configurations used for auto tiling. Three different "
"auto tiling configurations are possible if you want to use different config "
"on different monitors, virtual desktops or simply toggle between them. Only "
"one configuration can be used on same screen + virtual desktop + activity at "
"a time - if you try to mix them, the new configuration replaces the old one. "
"You can view instructions, predefined layouts (including pictures to give "
"you an idea what each one does) and user submitted layouts <a href=\"https://"
"github.com/rxappdev/MouseTiler/blob/main/AUTOTILERGUIDE.md\"><span style=\" "
"text-decoration: underline; color:#5294e2;\">here</span></a>.</p></body></"
"html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:46
msgid ""
"<html><head/><body><p>Designed to work optimally with my other script <a "
"href=\"https://github.com/rxappdev/RememberWindowPositions\"><span style=\" "
"text-decoration: underline; color:#007af4;\">Remember Window Positions</"
"span></a>.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:47
msgid ""
"<html><head/><body><p>Do not auto tile this long after session start (<span "
"style=\" color:#ffaa00;\">increase</span> to 10s or more if you use RWP)</"
"p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:48
msgid ""
"<html><head/><body><p>Format is same as Popup Grid Layouts. One layout per "
"line. Each line needs to have minimum X tiles where X is the line number. "
"Each tile needs to be prefixed with priority index starting at 0: on line 1. "
"Negative values are allowed to show windows at end of the list. Line 8 needs "
"tiles 0: and 7 other tiles ranging from -6: to 7: (8 numbers including 0). "
"Special tile *: can be used to create fixed tiles. *: tiles will not be be "
"re-prioritized and are simply there to allow mixed auto and normal layout. "
"Place *: in same spot on each layout for best experience.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:49
msgid ""
"<html><head/><body><p>If a keyboard shortcut does not work (perhaps due to "
"shortcut conflict), please manually assign it (or any shortcut you like) in "
"&quot;<span style=\" font-weight:700;\">System Settings &gt; Keyboard &gt; "
"Shortcuts &gt; Window Management &gt; Mouse Tiler: ...</span>&quot;.</p></"
"body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:50
msgid ""
"<html><head/><body><p>Max auto tile delay (<span style=\" "
"color:#ffaa00;\">increase</span> to 5s or more if you use Remember Window "
"Positions)</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:51
msgid ""
"<html><head/><body><p>Set all the layouts for the Popup mode - one layout "
"per line.</p><p>Valid formats:</p><p>[<span style=\" font-weight:700;\">WxH</"
"span>] - an W column wide and H rows high grid layout (example 4x2 will give "
"2 rows with 4 columns each for a total of 8 tiles)</p><p>[<span style=\" "
"font-weight:700;\">X,Y,Width,Height</span>] - an Width wide and Height tall "
"tile located at X and Y coordinates (example 20,10,400px,200px for a 400 "
"pixel wide, 200 pixel high tile placed at 20% screen width and 10% screen "
"height)</p><p>[<span style=\" font-"
"weight:700;\">X,Y,Width,Height,AnchorX,AnchorY</span>] - same as above, "
"except tile is placed using the tile anchor point (example "
"50,50,320px,240px,CENTER,CENTER to place a 320x240 pixel large tile in the "
"middle of the screen - without the CENTER anchor, the top-left corner would "
"end up in the middle of the screen instead)</p><p><span style=\" font-"
"weight:700;\">X</span>, <span style=\" font-weight:700;\">Y</span>, <span "
"style=\" font-weight:700;\">Width</span> and <span style=\" font-"
"weight:700;\">Height</span> can be in percent (usually between 0 and 100, "
"decimal values supported - recommended), pixels (absolute values using px "
"suffix - not recommended) and fractions (e.g. 1/3).</p><p><span style=\" "
"font-weight:700;\">AnchorX</span> can be a percentage (e.g. 50%) or fraction "
"(e.g. 1/2) of tile Width or one of <span style=\" font-weight:700;\">LEFT</"
"span>, <span style=\" font-weight:700;\">CENTER</span> or <span style=\" "
"font-weight:700;\">RIGHT</span>.</p><p><span style=\" font-"
"weight:700;\">AnchorY</span> can be a percentage (e.g. 50%) or fraction "
"(e.g. 1/2) of tile Height or one of <span style=\" font-weight:700;\">TOP</"
"span>, <span style=\" font-weight:700;\">CENTER</span> or <span style=\" "
"font-weight:700;\">BOTTOM</span>.</p><p>The layout can be made of multiple "
"grids and/or tiles separated by a + (example 0,0,50,100+50,0,50,100 which is "
"equal to a 2x1 grid).</p><p>You can also use one of these special layouts: "
"SPECIAL_FILL, SPECIAL_SPLIT_VERTICAL, SPECIAL_SPLIT_HORIZONTAL, "
"SPECIAL_MAXIMIZE, SPECIAL_MINIMIZE, SPECIAL_FULLSCREEN, SPECIAL_KEEP_ABOVE, "
"SPECIAL_KEEP_BELOW, SPECIAL_NO_TITLEBAR_AND_FRAME, SPECIAL_CLOSE, "
"SPECIAL_EMPTY, SPECIAL_AUTO_TILER_TOGGLE, SPECIAL_AUTO_TILER_1, "
"SPECIAL_AUTO_TILER_2 and SPECIAL_AUTO_TILER_3.</p></body></html>"
msgstr ""

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:52
msgid ""
"<html><head/><body><p>Set the layouts for the Popup mode - one layout per "
"line.</p><p>Valid formats:</p><p>[<span style=\" font-weight:700;\">WxH</"
"span>] - an W column wide and H rows high grid layout (example 4x2 will give "
"2 rows with 4 columns each for a total of 8 tiles)</p><p>[<span style=\" "
"font-weight:700;\">X,Y,Width,Height</span>] - an Width wide and Height tall "
"tile located at X and Y coordinates (example 20,10,400px,200px for a 400 "
"pixel wide, 200 pixel high tile placed at 20% screen width and 10% screen "
"height)</p><p>[<span style=\" font-"
"weight:700;\">X,Y,Width,Height,AnchorX,AnchorY</span>] - same as above, "
"except tile is placed using the tile anchor point (example "
"50,50,320px,240px,CENTER,CENTER to place a 320x240 pixel large tile in the "
"middle of the screen - without the CENTER anchor, the top-left corner would "
"end up in the middle of the screen instead)</p><p><span style=\" font-"
"weight:700;\">X</span>, <span style=\" font-weight:700;\">Y</span>, <span "
"style=\" font-weight:700;\">Width</span> and <span style=\" font-"
"weight:700;\">Height</span> can be in percent (usually between 0 and 100, "
"decimal values supported - recommended), pixels (absolute values using px "
"suffix - not recommended) and fractions (e.g. 1/3).</p><p><span style=\" "
"font-weight:700;\">AnchorX</span> can be a percentage (e.g. 50%) or fraction "
"(e.g. 1/2) of tile Width or one of <span style=\" font-weight:700;\">LEFT</"
"span>, <span style=\" font-weight:700;\">CENTER</span> or <span style=\" "
"font-weight:700;\">RIGHT</span>.</p><p><span style=\" font-"
"weight:700;\">AnchorY</span> can be a percentage (e.g. 50%) or fraction "
"(e.g. 1/2) of tile Height or one of <span style=\" font-weight:700;\">TOP</"
"span>, <span style=\" font-weight:700;\">CENTER</span> or <span style=\" "
"font-weight:700;\">BOTTOM</span>.</p><p>The layout can be made of multiple "
"grids and/or tiles separated by a + (example 0,0,50,100+50,0,50,100 which is "
"equal to a 2x1 grid).</p><p>You can also use one of these special layouts: "
"SPECIAL_FILL, SPECIAL_SPLIT_VERTICAL, SPECIAL_SPLIT_HORIZONTAL, "
"SPECIAL_MAXIMIZE, SPECIAL_MINIMIZE, SPECIAL_FULLSCREEN, SPECIAL_KEEP_ABOVE, "
"SPECIAL_KEEP_BELOW, SPECIAL_NO_TITLEBAR_AND_FRAME, SPECIAL_CLOSE, "
"SPECIAL_EMPTY, SPECIAL_AUTO_TILER_TOGGLE, SPECIAL_AUTO_TILER_1, "
"SPECIAL_AUTO_TILER_2 and SPECIAL_AUTO_TILER_3.</p></body></html>"
msgstr ""

