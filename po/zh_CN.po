#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:10
msgid ""
"<html><head/><body><p>&quot;<span style=\" font-weight:700;\">Popup Grid</"
"span>&quot; mode: Show or hide all layouts.</p><p>&quot;<span style=\" font-"
"weight:700;\">Overlay</span>&quot; mode: Start or stop spanning from the "
"hovered tile (a window can span multiple tiles).</p></body></html>"
msgstr "<html><head/><body><p>&quot;<span style=\" font-weight:700;\">弹出网格</span>&quot; 模式：显示或隐藏所有布局。</p><p>&quot;<span style=\" font-weight:700;\">覆盖平铺</span>&quot; 模式：从悬停的平铺块开始或停止跨越（一个窗口可以跨越多个平铺块）。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:11
msgid ""
"<html><head/><body><p><span style=\" color:#ff0000;\">To apply changes, "
"please disable (untick then click &quot;Apply&quot;), and re-enable (tick "
"then click &quot;Apply&quot;) the script (limitation of KDE). (Reboot works "
"too).</span></p></body></html>"
msgstr "<html><head/><body><p><span style=\" color:#ff0000;\">要应用更改，请禁用该脚本（取消勾选并点击“应用”），然后重新启用该脚本（勾选并点击“应用”）（这是 KDE 的限制，重启也同样有效）。</span></p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:12
msgid ""
"<html><head/><body><p><span style=\" color:#ffaa00;\">TIP</span> You can use "
"the <a href=\"https://rxweb.epizy.com/mousetiler/editor.html\"><span "
"style=\" text-decoration: underline; color:#5294e2;\">graphical web editor</"
"span></a> to edit existining, or create brand new layouts.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" color:#ffaa00;\">提示</span> 你可以使用 <a href=\"https://rxweb.epizy.com/mousetiler/editor.html\"><span style=\" text-decoration: underline; color:#5294e2;\">在线图形编辑器</span></a> 来编辑现有布局，或创建全新布局。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:13
msgid ""
"<html><head/><body><p><span style=\" color:#ffaa00;\">TIP</span> You can use "
"the <a href=\"https://rxweb.epizy.com/mousetiler/editor.html\"><span "
"style=\" text-decoration: underline; color:#5294e2;\">graphical web editor</"
"span></a> to edit the layout.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" color:#ffaa00;\">提示</span> 你可以使用 <a href=\"https://rxweb.epizy.com/mousetiler/editor.html\"><span style=\" text-decoration: underline; color:#5294e2;\">在线图形编辑器</span></a> 来编辑布局。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:14
msgid ""
"<html><head/><body><p><span style=\" color:#ffaa00;\">WARNING</span> Add "
"&quot;Auto tile for id&quot; or enable &quot;Auto tile newly opened "
"windows&quot; at own risk. It should be safe now since auto-tiling received "
"a lot of fixes and all known bugs have been fixed. But it is preferrable to "
"manually auto tile each app/window and save/restore the auto tile status "
"with Remember Window Positions (v5.4.1 or newer) if you can. Please report "
"problematic apps on Discord so I can add them to default blacklist.</p></"
"body></html>"
msgstr "<html><head/><body><p><span style=\" color:#ffaa00;\">警告</span> 添加 &quot;针对特定 ID 自动平铺&quot; 或启用 &quot;自动平铺新打开的窗口&quot; 需自担风险。由于自动平铺进行了大量修复，所有已知 Bug 均已修复，目前应该是安全的。但如果可以的话，最好手动对每个应用/窗口进行自动平铺，并配合 Remember Window Positions (v5.4.1或更高版本) 来保存/恢复自动平铺状态。请在 Discord 上反馈有问题的应用，以便我将它们加入默认黑名单。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:15
msgid ""
"<html><head/><body><p><span style=\" font-weight:400; "
"color:#ffaa00;\">DEFAULT </span>SPECIAL_AUTO_TILER_1</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:400; color:#ffaa00;\">默认 </span>SPECIAL_AUTO_TILER_1</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:16
msgid ""
"<html><head/><body><p><span style=\" font-weight:700; "
"color:#ffaa00;\">IMPORTANT Disable this</span>. I am sorry about the hint - "
"but I get questions regarding tiler visibility daily and people uninstall "
"because they do not check the settings.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700; color:#ffaa00;\">重要 禁用此项</span>。对于这个提示我感到很抱歉——但我每天都会收到关于平铺器可见性的问题，很多人因为没有检查设置就直接卸载了。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:17
msgid ""
"<html><head/><body><p><span style=\" font-weight:700; "
"color:#ffaa00;\">IMPORTANT</span> Default tiler visibility</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700; color:#ffaa00;\">重要</span> 默认平铺器可见性</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:18
msgid ""
"<html><head/><body><p><span style=\" font-weight:700; "
"color:#ffaa00;\">IMPORTANT</span> Please note that shortcuts have to be "
"configured in &quot;<span style=\" font-weight:700;\">System Settings &gt; "
"Keyboard &gt; Shortcuts &gt; Window Management &gt; Mouse Tiler: ...</"
"span>&quot; - this is just a list of shortcuts and explanation of what they "
"do. They can be edited here for the purpose of displaying correct hints in "
"the tiler but have no effect on actual keybinding.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700; color:#ffaa00;\">重要</span> 请注意，快捷键必须在 &quot;<span style=\" font-weight:700;\">系统设置 &gt; 键盘 &gt; 快捷键 &gt; 窗口管理 &gt; Mouse Tiler: ...</span>&quot; 中配置 - 这里只是快捷键列表和它们的作用说明。可以在这里编辑它们以便在平铺器中显示正确的提示，但对实际的键绑定没有影响。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:19
msgid ""
"<html><head/><body><p><span style=\" font-weight:700; "
"color:#ffaa00;\">IMPORTANT</span><span style=\" font-weight:700;\"> "
"Position</span>: Determines where the Popup Grid will be displayed. You can "
"chose to show it below mouse pointer or at a fixed screen position.</p></"
"body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700; color:#ffaa00;\">重要</span><span style=\" font-weight:700;\"> 位置</span>：确定弹出网格的显示位置。你可以选择在鼠标指针下方显示，或在固定的屏幕位置显示。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:20
msgid ""
"<html><head/><body><p><span style=\" font-weight:700; color:#ffaa00;\">READ "
"ME</span> There are a lot of settings, bust most people probably only want "
"to change 3 of them (visibility, position, and disable the hints). I have "
"marked them with <span style=\" font-weight:700; color:#ffaa00;\">IMPORTANT</"
"span> tag so they are easy to find.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700; color:#ffaa00;\">自述说明</span> 这里有很多设置，但大多数人可能只想更改其中的 3 个（显示/隐藏、位置和禁用提示）。我已经用 <span style=\" font-weight:700; color:#ffaa00;\">重要</span> 标签标记了它们，以便于查找。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:21
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">All Popup Grid "
"Layouts</span></p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">所有弹出网格布局</span></p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:22
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Auto Tiling</span>: "
"Configure the auto tilier behavior. <span style=\" color:#ffaa00;\">TIP</"
"span> You can use the <a href=\"https://rxweb.epizy.com/mousetiler/"
"editor.html\"><span style=\" text-decoration: underline; "
"color:#5294e2;\">graphical web editor</span></a> to edit layouts - but need "
"to manually add prefixes (such as 0:, 1:, 2:, -1 or *: )</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">自动平铺</span>：配置自动平铺的行为。<span style=\" color:#ffaa00;\">提示</span> 你可以使用 <a href=\"https://rxweb.epizy.com/mousetiler/editor.html\"><span style=\" text-decoration: underline; color:#5294e2;\">在线图形编辑器</span></a> 来编辑布局 - 但需要手动添加前缀（例如 0:, 1:, 2:, -1 或 *: ）。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:23
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Center In Tile</"
"span>: Configure how the center in tile works. You can toggle between "
"regular tiling, and centering in the tile by using the shortcut (<span "
"style=\" font-weight:700;\">Meta+Ctrl+C</span>).</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">平铺居中</span>：配置平铺居中的工作方式。你可以使用快捷键（<span style=\" font-weight:700;\">Meta+Ctrl+C</span>）在常规平铺和居中平铺之间切换。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:24
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Colors</span>: "
"Change the tiler color theme. By default the tiler follows your current "
"theme colors.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">颜色</span>：更改平铺器的颜色主题。默认情况下，平铺器会跟随你当前的主题颜色。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:25
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Debug Settings</"
"span>: Intended for development or when submitting a bug/issue to give more "
"details to the current issue. This might write a lot of data to the system "
"log. Not recommended for every day use.</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">调试设置</span>：用于开发或提交错误/问题时，以提供当前问题的更多细节。这可能会向系统日志中写入大量数据。不推荐日常使用。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:26
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Default Popup Grid "
"Layouts</span></p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">默认弹出网格布局</span></p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:27
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Default Shortcut</"
"span></p></body></html>"
msgstr ""
"<html><head/><body><p><span style=\" font-weight:700;\">Default Shortcut</"
"span></p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:28
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Default Tiler</"
"span>: This decides which tiler will show up when you start moving a window. "
"You can still toggle between the tilers by using the shortcut (<span "
"style=\" font-weight:700;\">Meta+Ctrl+Space</span>).</p></body></html>"
msgstr "<html><head/><body><p><span style=\" font-weight:700;\">默认平铺器</span>：这决定了开始移动窗口时将显示哪个平铺器。你仍然可以使用快捷键（<span style=\" font-weight:700;\">Meta+Ctrl+Space</span>）在平铺器之间切换。</p></body></html>"

#: /home/hu-hub/个人项目/开源项目/MouseTiler/src/contents/ui/config_strings.cpp:29
